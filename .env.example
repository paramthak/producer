# Required — Google Gemini API key (used for both frame description and match+trim)
GEMINI_API_KEY=

# Required — ElevenLabs API key (used for Forced Alignment of the voiceover)
ELEVENLABS_API_KEY=

# Required — plaintext credentials that gate the entire app.
# Anyone hitting the deployed URL must enter these to get in. No hashing —
# this is a light gate so random Vercel visitors can't burn your API keys.
AUTH_USERNAME=
AUTH_PASSWORD=

# Optional — override ffmpeg binary locations (defaults to PATH)
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Optional — override where session data is stored on disk. Defaults to
# .producer-data/ inside the project root. On Railway, set this to the
# volume mount path (e.g. /data) so uploads/frames/outputs survive redeploys.
# DATA_ROOT=/data

# Google Drive import (OAuth 2.0). Create a "Web application" OAuth client in
# Google Cloud Console (Google Auth Platform → Clients) with the Drive API
# enabled and the drive.readonly scope. Add BOTH redirect URIs to the client:
#   http://localhost:3000/api/drive/callback   (local dev)
#   https://<your-domain>/api/drive/callback   (production)
# Client ID + secret are the same everywhere; only the redirect URI differs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback
