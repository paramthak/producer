# Required — Google Gemini API key (used for both frame description and match+trim)
GEMINI_API_KEY=

# Required — ElevenLabs API key (used for Forced Alignment of the voiceover)
ELEVENLABS_API_KEY=

# Optional — override ffmpeg binary locations (defaults to PATH)
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
